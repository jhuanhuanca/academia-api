# =============================================================================
# academia-api — PRODUCCIÓN (api.apaflow.shop)
# En el VPS: cp .env.production.example .env  (NO reemplaza tu .env local de XAMPP)
# =============================================================================

APP_NAME=ApaFlow
APP_ENV=production
APP_KEY=                    # php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.apaflow.shop

FRONTEND_URL=https://apaflow.shop

# Motor IA — llamada interna en el mismo VPS (más rápido y seguro)
LUNA_BASE_URL=http://127.0.0.1:8001
# Alternativa vía subdominio público:
# LUNA_BASE_URL=https://ia.apaflow.shop
LUNA_API_KEY=CAMBIAR-clave-luna-produccion-larga
LUNA_TIMEOUT=25

# Evolution — Docker en localhost, Nginx expone main.apaflow.shop
EVOLUTION_BASE_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=CAMBIAR-clave-evolution-produccion-larga
EVOLUTION_TIMEOUT=30
EVOLUTION_INSTANCE=apaflow-ventas
EVOLUTION_WEBHOOK_URL=https://api.apaflow.shop/api/webhooks/evolution

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apaflow_chatbot
DB_USERNAME=apaflow
DB_PASSWORD=CAMBIAR-mysql-password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CAMBIAR-redis-password
REDIS_PORT=6379

# Gmail / SMTP producción
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=contraseña-de-aplicacion-google
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=apaflow.shop,www.apaflow.shop
SESSION_DOMAIN=.apaflow.shop
CORS_ALLOWED_ORIGINS=https://apaflow.shop,https://www.apaflow.shop
